  "scripts": {
    "start:server": "nx serve server",
    "start:client": "nx serve client --proxy-config proxy.conf.json",
    "dev": "nx run-many --target=build --projects=server,client --watch",
    "build:server": "nx build server",
    "build:client": "nx build client",
    "build": "nx build client && nx build server && cp -R apps/server/src/assets dist/apps/server",
    "test:server": "nx test server",
    "test:client": "nx test client",
    "e2e": "nx e2e client-e2e",
    "workspace-schematic": "./node_modules/.bin/nx workspace-schematic",
    "dep-graph": "./node_modules/.bin/nx dep-graph",
    "postinstall": "rm -rf node_modules/fhir/node_modules/lodash && cp -R node_modules/lodash node_modules/fhir/node_modules/lodash && node -e \"const fs=require('fs');const f='package-lock.json';const j=JSON.parse(fs.readFileSync(f,'utf8'));const p=j.packages['node_modules/fhir/node_modules/lodash'];if(p){p.version='4.18.1';fs.writeFileSync(f,JSON.stringify(j,null,2)+'\\n')}\""
  },
